<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260415180000-1" author="app">
        <addColumn tableName="repair_request">
            <column name="company_site_report" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="repair_request">
            <column name="reported_location_id" type="bigint">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint
            baseColumnNames="reported_location_id"
            baseTableName="repair_request"
            constraintName="fk_repair_request_reported_location"
            referencedColumnNames="id"
            referencedTableName="location"/>
    </changeSet>
</databaseChangeLog>
