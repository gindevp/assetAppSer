<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity StockIssue.
    -->
    <changeSet id="20260328142651-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="issue_id"
                                 baseTableName="stock_issue"
                                 constraintName="fk_stock_issue__issue_id"
                                 referencedColumnNames="id"
                                 referencedTableName="stock_issue"
                                 />

        <addForeignKeyConstraint baseColumnNames="employee_id"
                                 baseTableName="stock_issue"
                                 constraintName="fk_stock_issue__employee_id"
                                 referencedColumnNames="id"
                                 referencedTableName="employee"
                                 />

        <addForeignKeyConstraint baseColumnNames="department_id"
                                 baseTableName="stock_issue"
                                 constraintName="fk_stock_issue__department_id"
                                 referencedColumnNames="id"
                                 referencedTableName="department"
                                 />

        <addForeignKeyConstraint baseColumnNames="location_id"
                                 baseTableName="stock_issue"
                                 constraintName="fk_stock_issue__location_id"
                                 referencedColumnNames="id"
                                 referencedTableName="location"
                                 />
    </changeSet>
</databaseChangeLog>
