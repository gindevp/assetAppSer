<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260406120000-1" author="app">
        <createTable tableName="loss_report_request">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="request_date" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="loss_kind" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="integer"/>
            <column name="reason" type="varchar(2000)"/>
            <column name="requester_id" type="bigint"/>
            <column name="equipment_id" type="bigint"/>
            <column name="consumable_assignment_id" type="bigint"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="requester_id" baseTableName="loss_report_request"
            constraintName="fk_loss_report_request_requester"
            referencedColumnNames="id" referencedTableName="employee"/>
        <addForeignKeyConstraint baseColumnNames="equipment_id" baseTableName="loss_report_request"
            constraintName="fk_loss_report_request_equipment"
            referencedColumnNames="id" referencedTableName="equipment"/>
        <addForeignKeyConstraint baseColumnNames="consumable_assignment_id" baseTableName="loss_report_request"
            constraintName="fk_loss_report_request_consumable_assignment"
            referencedColumnNames="id" referencedTableName="consumable_assignment"/>
    </changeSet>
</databaseChangeLog>
